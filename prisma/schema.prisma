generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Çok dilli metinler Json alanlarda { "tr": "...", "en": "...", "ar": "..." } olarak saklanır.

model SiteSettings {
  id              Int      @id @default(1)
  logoHeaderUrl   String?
  logoFooterUrl   String?
  logoHeight      Int?     @default(60)
  faviconUrl      String?
  whatsappNumber  String?
  whatsappMessage Json?
  heroTitle       Json?
  heroSubtitle    Json?
  brandColors     Json?
  mapImageUrl     String?
  mapTitle        Json?
  mapDescription  Json?
  contactEmail    String?
  contactAddress  Json?
  heroVideoUrl    String?
  heroOverlay     Float?   @default(0.5)
  storyTitle      Json?
  storyText       Json?
  storyImageUrl   String?
  privacyPolicy   Json?
  cookiePolicy    Json?
  enabledLocales  String[] @default(["tr", "en", "ar"])
  updatedAt       DateTime @updatedAt
}

model SocialLink {
  id       String @id @default(cuid())
  platform String
  url      String
  order    Int    @default(0)
}

model ProductCategory {
  id       String    @id @default(cuid())
  name     Json
  slug     String    @unique
  order    Int       @default(0)
  products Product[]
}

model Product {
  id                String           @id @default(cuid())
  title             Json
  slug              String           @unique
  shortDescription  Json?
  ingredients       Json?
  nutritionInfo     Json?
  primaryImageUrl   String?
  secondaryImageUrl String?
  categoryId        String?
  category          ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orders            Order[]
  featured          Boolean          @default(false)
  price             Decimal?         @db.Decimal(10, 2)
  oldPrice          Decimal?         @db.Decimal(10, 2)
  showPrice         Boolean          @default(false)
  portions          Json?            // [{ persons: number, price: number, oldPrice?: number }]
  order             Int              @default(0)
  createdAt         DateTime         @default(now())
}

model MapPin {
  id            String  @id @default(cuid())
  cityName      String
  x             Float
  y             Float
  ingredient    Json
  popupTitle    Json?
  popupBody     Json?
  popupMediaUrl String?
  order         Int     @default(0)
}

model Reel {
  id           String @id @default(cuid())
  title        Json?
  coverUrl     String
  videoUrl     String?
  instagramUrl String?
  order        Int    @default(0)
}

model Branch {
  id           String  @id @default(cuid())
  name         String
  address      Json?
  phone        String?
  mapsEmbedUrl String?
  workingHours Json?
  order        Int     @default(0)
}

model News {
  id        String   @id @default(cuid())
  title     Json
  body      Json?
  imageUrl  String?
  published Boolean  @default(false)
  asPopup   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FranchiseFaq {
  id       String @id @default(cuid())
  question Json
  answer   Json
  order    Int    @default(0)
}

model FranchiseApplication {
  id           String   @id @default(cuid())
  name         String
  phone        String
  city         String
  budget       String?
  locationNote String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
}

model PageContent {
  id      String @id @default(cuid())
  key     String @unique
  content Json
}

model FreePage {
  id        String  @id @default(cuid())
  slug      String  @unique
  title     Json
  blocks    Json
  published Boolean @default(false)
}

model SeoMeta {
  id          String  @id @default(cuid())
  path        String  @unique
  title       Json?
  description Json?
  ogImageUrl  String?
}

model Order {
  id            String   @id @default(cuid())
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productTitle  String
  persons       Int?
  price         Decimal? @db.Decimal(10, 2)
  customerName  String?
  customerPhone String?
  addressNote   String?
  note          String?
  locationUrl   String?
  lat           Float?
  lng           Float?
  status        String   @default("new")
  createdAt     DateTime @default(now())
}
